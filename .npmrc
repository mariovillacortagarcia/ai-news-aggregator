# Security: wait 1 day before installing new package versions
# Helps filter out malicious packages detected within hours
min-release-age=1

# Security: disable lifecycle scripts (preinstall, install, postinstall)
# Prevents malicious code execution during installation
ignore-scripts=true

# Security: pin exact versions instead of semver ranges
# Prevents automatic upgrades to potentially compromised versions
save-exact=true

# Security: enforce engine requirements from package.json
engine-strict=true

# Security: only show high/critical vulnerabilities in audit output
audit-level=high

# Security: enable provenance attestation verification
provenance=true

# Security: verify SSL certificates (should always be true)
strict-ssl=true
