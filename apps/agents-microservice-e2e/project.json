{
  "name": "agents-microservice-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["agents-microservice"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/agents-microservice-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["agents-microservice:build"]
    }
  }
}
