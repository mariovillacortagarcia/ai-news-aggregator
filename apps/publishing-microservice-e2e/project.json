{
  "name": "publishing-microservice-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["publishing-microservice"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/publishing-microservice-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": [
        "publishing-microservice:build",
        "publishing-microservice:serve"
      ]
    }
  }
}
