{
  "name": "@ai-news-aggregator/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build:ingestion": "npx nx build ingestion-microservice",
    "start:ingestion": "npm run build:ingestion && /bin/zsh -lc 'set -a; source .env; set +a; node dist/apps/ingestion-microservice/main.js'",
    "dev:ingestion": "npx nx serve ingestion-microservice",
    "test:ingestion": "npx nx test ingestion-microservice",
    "test:ingestion:watch": "npx nx test ingestion-microservice --watch",
    "test:ingestion:coverage": "npx nx test ingestion-microservice --coverage",
    "e2e:ingestion": "npx nx e2e ingestion-microservice-e2e",
    "e2e:ingestion:watch": "npx nx e2e ingestion-microservice-e2e --watch",
    "lint:ingestion": "npx nx lint ingestion-microservice",
    "cucumber:ingestion": "npx nx run ingestion-microservice:test:e2e",
    "build:agents": "npx nx build agents-microservice",
    "start:agents": "npm run build:agents && /bin/zsh -lc 'set -a; source .env; set +a; node dist/apps/agents-microservice/main.js'",
    "dev:agents": "npx nx serve agents-microservice",
    "test:agents": "npx nx test agents-microservice",
    "test:agents:watch": "npx nx test agents-microservice --watch",
    "test:agents:coverage": "npx nx test agents-microservice --coverage",
    "e2e:agents": "npx nx e2e agents-microservice-e2e",
    "e2e:agents:watch": "npx nx e2e agents-microservice-e2e --watch",
    "cucumber:agents": "npx nx run agents-microservice:test:e2e",
    "build:all": "npx nx run-many -t build",
    "test:all": "npx nx run-many -t test",
    "e2e:all": "npx nx run-many -t e2e"
  },
  "private": true,
  "dependencies": {
    "@langchain/core": "1.1.46",
    "@langchain/langgraph": "1.3.0",
    "@langchain/openai": "1.4.5",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/cheerio": "^0.22.35",
    "@types/node-cron": "^3.0.11",
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "joi": "^18.2.1",
    "langchain": "1.4.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.3",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "22.7.2",
    "@nx/eslint-plugin": "22.7.2",
    "@nx/jest": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/nest": "22.7.2",
    "@nx/node": "22.7.2",
    "@nx/web": "22.7.2",
    "@nx/webpack": "22.7.2",
    "@nx/workspace": "22.7.2",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "nx": "22.7.2",
    "prettier": "~3.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack-cli": "^5.1.4"
  },
  "overrides": {
    "yaml": "2.9.0"
  }
}
